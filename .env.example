# Server
HOST=0.0.0.0
PORT=8080
NODE_ENV=production

# Database
# The Rust service accepts sqlite paths like:
#   DATABASE_URL=sqlite:./prisma/dev.db
# It also normalizes file: URLs if you prefer:
#   DATABASE_URL=file:./prisma/dev.db
DATABASE_URL=sqlite:./prisma/dev.db

# Blossom
BLOSSOM_SERVER_URL=http://blossom:3000
BLOSSOM_PUBLIC_URL=https://blossom.tubestr.app

# NIP-98 auth
NIP98_CHALLENGE_TTL_SECONDS=300

# Free trial
FREE_TRIAL_MODE=false
FREE_TRIAL_DAYS=30

# Reserved for future subscription/webhook validation work.
# The current Rust service does not read these yet.
# Apple App Store Server API
APPLE_ISSUER_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_BASE64=
APPLE_ENVIRONMENT=Production

# Google Play
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY_BASE64=

# Moderator key endpoint
MODERATOR_NPUB=
MODERATOR_PUBLIC_KEY=

# Safety HQ
# If unset, the backend will generate a stable key once and persist it in the DB.
# For production, prefer pinning this through your secret manager.
SAFETY_HQ_SECRET_KEY_HEX=
SAFETY_HQ_RELAYS=wss://no.str.cr,wss://relay.primal.net,wss://nos.lol
SAFETY_HQ_VERSION=v1
SAFETY_HQ_MDK_DB_PATH=./data/safety-hq-mdk.sqlite

# Cloudflare tunnel (used by docker-compose tunnel service)
CLOUDFLARE_TUNNEL_TOKEN=
